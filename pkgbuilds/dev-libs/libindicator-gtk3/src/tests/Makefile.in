@USE_GTK3_TRUE@	-DSRCDIR="\"$(srcdir)\"" \
@USE_GTK3_TRUE@	-DBUILD_DIR="\"$(abs_builddir)\"" \
@USE_GTK3_TRUE@	-Wall

