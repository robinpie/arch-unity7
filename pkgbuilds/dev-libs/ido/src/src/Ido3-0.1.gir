      <constructor name="new"
                   c:identifier="ido_message_dialog_new"
                   introspectable="0">
        <doc xml:space="preserve"
             filename="idomessagedialog.c"
             line="244">Creates a new message dialog, which is based upon
GtkMessageDialog so it shares API and functionality
with it.  IdoMessageDialog differs in that it has two
states.  The initial state hides the action buttons
and the secondary message.  When a user clicks on the
dialog it will expand to provide the secondary message
and the action buttons.</doc>
        <source-position filename="idomessagedialog.h" line="62"/>
        <return-value transfer-ownership="none">
          <doc xml:space="preserve"
               filename="idomessagedialog.c"
               line="261">a new #IdoMessageDialog</doc>
          <type name="Gtk.Widget" c:type="GtkWidget*"/>
        </return-value>
        <parameters>
          <parameter name="parent" transfer-ownership="none">
            <doc xml:space="preserve"
                 filename="idomessagedialog.c"
                 line="246">transient parent, or %NULL for none</doc>
            <type name="Gtk.Window" c:type="GtkWindow*"/>
          </parameter>
          <parameter name="flags" transfer-ownership="none">
            <doc xml:space="preserve"
