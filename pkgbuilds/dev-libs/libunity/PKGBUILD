# Maintainer: arch-unity7 port
# Upstream: https://launchpad.net/libunity
# Note: orig.tar.gz extracts flat; debian.tar.xz extracts to debian/ in srcdir

pkgname=libunity
pkgver=7.1.4
_uver=+19.04.20190319
_urev=6.1ubuntu1
pkgrel=1
pkgdesc="Library for instrumenting and integrating with the Unity shell"
arch=('x86_64')
url="https://launchpad.net/libunity"
license=('GPL-3.0-or-later' 'LGPL-3.0-or-later')
depends=('dee' 'glib2' 'libdbusmenu-glib' 'dconf' 'python3' 'python-gobject')
makedepends=('pkgconf' 'autoconf' 'automake' 'libtool' 'gnome-common'
             'gobject-introspection' 'vala' 'dbus' 'xorg-xauth'
             'xorg-server-xvfb' 'python3')
source=(
    "https://launchpad.net/ubuntu/+archive/primary/+files/${pkgname}_${pkgver}${_uver}.orig.tar.gz"
    "https://launchpad.net/ubuntu/+archive/primary/+files/${pkgname}_${pkgver}${_uver}-${_urev}.debian.tar.xz"
)
sha256sums=('SKIP' 'SKIP')

prepare() {
    # orig.tar.gz extracts flat; debian.tar.xz extracts to $srcdir/debian/
    cd "$srcdir"

    # Fix gcc 14+ build: visibility attribute issue
    if [ -f src/unity-filters.vala ]; then
        sed -i '/\[CCode.*cname.*unity_filters_new\]/d' src/unity-filters.vala 2>/dev/null || true
    fi

    # Apply debian patches
    if [ -f debian/patches/series ]; then
        while IFS= read -r p || [ -n "$p" ]; do
            [[ "$p" =~ ^[[:space:]]*# ]] || [ -z "$p" ] && continue
            [ -f "debian/patches/$p" ] && patch -p1 -i "debian/patches/$p"
        done < debian/patches/series
    fi

    autoreconf -fiv
}

build() {
    cd "$srcdir"
    ./configure \
        --prefix=/usr \
        --libdir=/usr/lib \
        --disable-static \
        --disable-headless-tests
    make
}

package() {
    cd "$srcdir"
    make DESTDIR="$pkgdir" install
    find "$pkgdir" -name '*.la' -delete
}
