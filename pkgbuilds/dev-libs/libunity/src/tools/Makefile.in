  --pkg config \
  --pkg gtk+-3.0 \
  --pkg gmodule-2.0 \
  --pkg unity-internal \
  --pkg unity-protocol \
  $(LIBUNITY_PACKAGES) \
  $(MAINTAINER_VALAFLAGS)

