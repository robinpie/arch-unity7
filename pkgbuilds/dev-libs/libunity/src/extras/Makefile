install-extrasgirDATA: $(extrasgir_DATA)
	@$(NORMAL_INSTALL)
	@list='$(extrasgir_DATA)'; test -n "$(extrasgirdir)" || list=; \
	if test -n "$$list"; then \
	  echo " $(MKDIR_P) '$(DESTDIR)$(extrasgirdir)'"; \
	  $(MKDIR_P) "$(DESTDIR)$(extrasgirdir)" || exit 1; \
	fi; \
	for p in $$list; do \
	  if test -f "$$p"; then d=; else d="$(srcdir)/"; fi; \
	  echo "$$d$$p"; \
	done | $(am__base_list) | \
	while read files; do \
	  echo " $(INSTALL_DATA) $$files '$(DESTDIR)$(extrasgirdir)'"; \
	  $(INSTALL_DATA) $$files "$(DESTDIR)$(extrasgirdir)" || exit $$?; \
	done

uninstall-extrasgirDATA:
	@$(NORMAL_UNINSTALL)
	@list='$(extrasgir_DATA)'; test -n "$(extrasgirdir)" || list=; \
	files=`for p in $$list; do echo $$p; done | sed -e 's|^.*/||'`; \
	dir='$(DESTDIR)$(extrasgirdir)'; $(am__uninstall_files_from_dir)
