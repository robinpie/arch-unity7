.PRECIOUS: Makefile


unity.deps:
	$(AM_V_GEN)echo "$(LIBUNITY_DEPS_PACKAGES)" | sed 's/ /\n/g' | sed '/^$$/d' > $@

$(libunity_la_GENERATED): libunity_la_vala.stamp

libunity_la_vala.stamp: $(libunity_la_VALASOURCES)
	$(AM_V_GEN) $(VALAC) $(libunity_la_VALAFLAGS) $^
	@touch $@
@HAVE_INTROSPECTION_TRUE@$(unitygir_DATA): libunity_la_vala.stamp
@HAVE_INTROSPECTION_TRUE@$(typelib_DATA): $(unitygir_DATA) libunity.la
@HAVE_INTROSPECTION_TRUE@	@INTROSPECTION_COMPILER@ $(INTROSPECTION_COMPILER_ARGS) -o $@ $^

# Tell versions [3.59,3.63) of GNU make to not export all variables.
# Otherwise a system limit (for SysV at least) may be exceeded.
.NOEXPORT:

# Tell GNU make to disable its built-in pattern rules.
