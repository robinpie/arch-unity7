# Extract dlname from libunity.la
# This is what g-ir-scanner does.
libunity_dlname = \
	`$(SED) -nE "s/^dlname='([A-Za-z0-9.+-]+)'/\1/p" libunity.la`

INTROSPECTION_COMPILER_ARGS = \
	--includedir=$(srcdir) \
	-l $(libunity_dlname)

