install-dist_unityvapiDATA: $(dist_unityvapi_DATA)
	@$(NORMAL_INSTALL)
	@list='$(dist_unityvapi_DATA)'; test -n "$(unityvapidir)" || list=; \
	if test -n "$$list"; then \
	  echo " $(MKDIR_P) '$(DESTDIR)$(unityvapidir)'"; \
	  $(MKDIR_P) "$(DESTDIR)$(unityvapidir)" || exit 1; \
	fi; \
	for p in $$list; do \
	  if test -f "$$p"; then d=; else d="$(srcdir)/"; fi; \
	  echo "$$d$$p"; \
	done | $(am__base_list) | \
	while read files; do \
	  echo " $(INSTALL_DATA) $$files '$(DESTDIR)$(unityvapidir)'"; \
	  $(INSTALL_DATA) $$files "$(DESTDIR)$(unityvapidir)" || exit $$?; \
	done

uninstall-dist_unityvapiDATA:
	@$(NORMAL_UNINSTALL)
	@list='$(dist_unityvapi_DATA)'; test -n "$(unityvapidir)" || list=; \
	files=`for p in $$list; do echo $$p; done | sed -e 's|^.*/||'`; \
	dir='$(DESTDIR)$(unityvapidir)'; $(am__uninstall_files_from_dir)
