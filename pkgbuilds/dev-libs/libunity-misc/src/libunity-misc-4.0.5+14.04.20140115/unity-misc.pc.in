prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@

Name: libunity-misc
Description: A library to build misc for Unity
Version: @VERSION@
Libs: -L${libdir} -lunity-misc
Cflags: -I${includedir}/unity-misc
Requires: glib-2.0 gthread-2.0 gobject-2.0 gio-2.0 gio-unix-2.0 gtk+-3.0
