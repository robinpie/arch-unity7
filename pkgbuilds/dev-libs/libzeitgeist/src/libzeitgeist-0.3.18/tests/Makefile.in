zeitgeist-mimetypes.obj: $(top_srcdir)/src/zeitgeist-mimetypes.c
@am__fastdepCC_TRUE@	$(AM_V_CC)$(CC) $(DEFS) $(DEFAULT_INCLUDES) $(INCLUDES) $(AM_CPPFLAGS) $(CPPFLAGS) $(AM_CFLAGS) $(CFLAGS) -MT zeitgeist-mimetypes.obj -MD -MP -MF $(DEPDIR)/zeitgeist-mimetypes.Tpo -c -o zeitgeist-mimetypes.obj `if test -f '$(top_srcdir)/src/zeitgeist-mimetypes.c'; then $(CYGPATH_W) '$(top_srcdir)/src/zeitgeist-mimetypes.c'; else $(CYGPATH_W) '$(srcdir)/$(top_srcdir)/src/zeitgeist-mimetypes.c'; fi`
@am__fastdepCC_TRUE@	$(AM_V_at)$(am__mv) $(DEPDIR)/zeitgeist-mimetypes.Tpo $(DEPDIR)/zeitgeist-mimetypes.Po
