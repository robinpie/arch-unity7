  -C \
  --pkg dee-1.0 \
  --pkg sqlite3 \
  --pkg unity \
  --pkg unity-extras \
  --pkg gee-0.8 \
  --pkg gio-2.0 \
  --pkg gio-unix-2.0 \
  --pkg glib-2.0 \
  --vapidir $(srcdir) \
  --pkg tdb \
  --target-glib=2.32 \
  $(MAINTAINER_VALAFLAGS)

