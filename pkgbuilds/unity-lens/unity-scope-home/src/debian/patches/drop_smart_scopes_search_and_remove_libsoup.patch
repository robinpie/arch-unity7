-        var retry_delay = int.min (REMOTE_SCOPES_INITIAL_RETRY_INTERVAL_SECS * ++remote_scopes_retry_count,
-                                   REMOTE_SCOPES_RETRY_INTERVAL_MAX_SECS);
-        debug ("Network is available, will retry in %d secs", retry_delay);
-        GLib.Timeout.add_seconds (retry_delay, request_remote_scopes_retry);
-      }
