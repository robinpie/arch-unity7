CategoryIcon=@prefix@/share/icons/unity-icon-theme/places/svg/group-music.svg
_Name=Music
_SearchHint=Search music
Type=music
IsMaster=true
Shortcut=m
_Keywords=music;
_NoContentHint=There is no music currently available on this computer.

[Desktop Entry]
X-Ubuntu-Gettext-Domain=unity-scope-home

