--- unity-lens-photos-1.0+17.10.20170605.orig/debian/control
+++ unity-lens-photos-1.0+17.10.20170605/debian/control
@@ -0,0 +1,36 @@
+Source: unity-lens-photos
+Section: gnome
+Priority: optional
+Maintainer: Ubuntu Desktop Team <ubuntu-desktop@lists.ubuntu.com>
+Build-Depends: debhelper (>= 9), 
+               dh-python,
+               python3, 
+               python3-distutils-extra, 
+               dh-python,
+               dh-translations
+Standards-Version: 3.9.3
+# If you aren't a member of ~unity-lens-photos but need to upload packaging
+# changes, just go ahead.  ~unity-lens-photos will notice and sync up the code
+# again.
+Vcs-Bzr: https://code.launchpad.net/~unity-lens-photos/unity-lens-photos/trunk
+X-Ubuntu-Use-Langpack: yes
+
+Package: unity-lens-photos
+Architecture: all
+Depends: ${misc:Depends},
+         ${shlibs:Depends},
+         ${python3:Depends},
+         gir1.2-accounts-1.0,
+         gir1.2-dee-1.0 (>= 1.2.5),
+         gir1.2-gdata-0.0,
+         gir1.2-signon-2.0,
+         gir1.2-soup-2.4,
+         gir1.2-unity-7.0 (>= 7),
+         python3-httplib2,
+         python3-oauthlib,
+Recommends: shotwell
+Breaks: unity-lens-photo
+Replaces: unity-lens-photo
+Description: Photos lens for Unity
+ This package contains photos scopes which allow Unity
+ to search for local photos using Shotwell.
