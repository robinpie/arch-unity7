--- unity-lens-photos-1.0+17.10.20170605.orig/debian/rules
+++ unity-lens-photos-1.0+17.10.20170605/debian/rules
@@ -0,0 +1,15 @@
+#!/usr/bin/make -f
+# -*- makefile -*-
+
+
+%:
+	dh $@ --with python3,translations --buildsystem=pybuild
+
+override_dh_install:
+	dh_install --fail-missing
+
+override_dh_auto_build:
+	python3 setup.py build
+
+override_dh_auto_install:
+	python3 setup.py install --root=$(CURDIR)/debian/unity-lens-photos --install-layout=deb
