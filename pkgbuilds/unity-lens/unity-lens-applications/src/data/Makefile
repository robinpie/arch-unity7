install-appscopeDATA: $(appscope_DATA)
	@$(NORMAL_INSTALL)
	@list='$(appscope_DATA)'; test -n "$(appscopedir)" || list=; \
	if test -n "$$list"; then \
	  echo " $(MKDIR_P) '$(DESTDIR)$(appscopedir)'"; \
	  $(MKDIR_P) "$(DESTDIR)$(appscopedir)" || exit 1; \
	fi; \
	for p in $$list; do \
	  if test -f "$$p"; then d=; else d="$(srcdir)/"; fi; \
	  echo "$$d$$p"; \
	done | $(am__base_list) | \
	while read files; do \
	  echo " $(INSTALL_DATA) $$files '$(DESTDIR)$(appscopedir)'"; \
	  $(INSTALL_DATA) $$files "$(DESTDIR)$(appscopedir)" || exit $$?; \
	done

