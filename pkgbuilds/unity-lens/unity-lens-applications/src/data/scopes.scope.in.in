[Scope]
DBusName=com.canonical.Unity.Scope.Applications
DBusPath=/com/canonical/unity/scope/scopes
Module=@libdir@/unity/unity-scope-applications.so
ModuleType=C
Icon=@prefix@/share/unity/icons/lens-nav-app.svg
_Name=Dash plugins
_Description=This is an Ubuntu search plugin that enables information from available search plugins to be searched and displayed in the Dash underneath the Dash plugins header. If you do not wish to search this content source, you can disable this search plugin.
Type=applications
_SearchHint=Search search plugins
OptionalMetadata=scope_disabled[u]

[Desktop Entry]
X-Ubuntu-Gettext-Domain=unity-lens-applications

