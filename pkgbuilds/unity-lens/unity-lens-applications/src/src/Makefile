install-unitylibLTLIBRARIES: $(unitylib_LTLIBRARIES)
	@$(NORMAL_INSTALL)
	@list='$(unitylib_LTLIBRARIES)'; test -n "$(unitylibdir)" || list=; \
	list2=; for p in $$list; do \
	  if test -f $$p; then \
	    list2="$$list2 $$p"; \
	  else :; fi; \
	done; \
	test -z "$$list2" || { \
	  echo " $(MKDIR_P) '$(DESTDIR)$(unitylibdir)'"; \
	  $(MKDIR_P) "$(DESTDIR)$(unitylibdir)" || exit 1; \
	  echo " $(LIBTOOL) $(AM_LIBTOOLFLAGS) $(LIBTOOLFLAGS) --mode=install $(INSTALL) $(INSTALL_STRIP_FLAG) $$list2 '$(DESTDIR)$(unitylibdir)'"; \
	  $(LIBTOOL) $(AM_LIBTOOLFLAGS) $(LIBTOOLFLAGS) --mode=install $(INSTALL) $(INSTALL_STRIP_FLAG) $$list2 "$(DESTDIR)$(unitylibdir)"; \
	}

uninstall-unitylibLTLIBRARIES:
	@$(NORMAL_UNINSTALL)
	@list='$(unitylib_LTLIBRARIES)'; test -n "$(unitylibdir)" || list=; \
	for p in $$list; do \
	  $(am__strip_dir) \
	  echo " $(LIBTOOL) $(AM_LIBTOOLFLAGS) $(LIBTOOLFLAGS) --mode=uninstall rm -f '$(DESTDIR)$(unitylibdir)/$$f'"; \
	  $(LIBTOOL) $(AM_LIBTOOLFLAGS) $(LIBTOOLFLAGS) --mode=uninstall rm -f "$(DESTDIR)$(unitylibdir)/$$f"; \
	done

clean-unitylibLTLIBRARIES:
	-$(am__rm_f) $(unitylib_LTLIBRARIES)
	@list='$(unitylib_LTLIBRARIES)'; \
	locs=`for p in $$list; do echo $$p; done | \
	      sed 's|^[^/]*$$|.|; s|/[^/]*$$||; s|$$|/so_locations|' | \
	      sort -u`; \
	echo rm -f $${locs}; \
	$(am__rm_f) $${locs}

