  --pkg posix \
  --pkg gio-2.0 \
  --pkg gio-unix-2.0 \
  --pkg dee-1.0 \
  --pkg zeitgeist-1.0 \
  --pkg unity \
  --pkg unity-protocol \
  --pkg gee-0.8 \
  --pkg libgnome-menu-3.0 \
  --pkg unity-package-search \
  --pkg unity-ratings-db \
  --target-glib=2.26 \
  $(MAINTAINER_VALAFLAGS)

