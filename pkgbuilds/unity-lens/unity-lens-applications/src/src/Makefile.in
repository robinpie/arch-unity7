unity_scope_applications_la_SOURCES = \
  $(unity_scope_applications_la_VALASOURCES:.vala=.c) \
  unity-package-search.cc \
  unity-package-search.h \
  unity-ratings-db.c \
  unity-ratings-db.h \
  $(NULL)

unity_scope_runningapps_la_SOURCES = \
