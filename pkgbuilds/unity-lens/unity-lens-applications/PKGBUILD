# Maintainer: arch-unity7 port
# Upstream: https://launchpad.net/unity-lens-applications

pkgname=unity-lens-applications
pkgver=7.1.0
_uver=+16.10.20160927
_urev=0ubuntu8
pkgrel=1
pkgdesc="Application lens for the Unity7 user interface"
arch=('x86_64')
url="https://launchpad.net/unity-lens-applications"
license=('GPL-3.0-or-later')
depends=(
    'dee'
    'glib2'
    'libcolumbus'
    'libgee'
    'libunity'
    'libzeitgeist'
    'xapian-core'
    'gnome-menus'
    'db'
)
makedepends=(
    'pkgconf'
    'vala'
    'gnome-common'
    'autoconf'
    'automake'
    'libtool'
)
source=(
    "https://launchpad.net/ubuntu/+archive/primary/+files/${pkgname}_${pkgver}${_uver}.orig.tar.gz"
    "https://launchpad.net/ubuntu/+archive/primary/+files/${pkgname}_${pkgver}${_uver}-${_urev}.diff.gz"
    "remove-software-center-filter-option.patch"
)
sha256sums=('SKIP' 'SKIP' 'SKIP')

prepare() {
    cd "$srcdir"

    # Apply Ubuntu diff (flat extraction)
    patch -p1 --batch --forward -i "${pkgname}_${pkgver}${_uver}-${_urev}.diff" || true

    # Apply debian patch series
    if [ -f debian/patches/series ] && [ ! -f .pc/applied-patches ]; then
        while IFS= read -r p || [ -n "$p" ]; do
            [[ "$p" =~ ^[[:space:]]*# ]] || [ -z "$p" ] && continue
            [ -f "debian/patches/$p" ] && patch -p1 -i "debian/patches/$p" || true
        done < debian/patches/series
    fi

    patch -p1 -i ../remove-software-center-filter-option.patch

    # Clear translations
    > po/LINGUAS || true

    # Remove the db5.3-specific version check (Arch ships db 6.2 which is compatible API)
    sed -i '/#error.*libdb-5.3/d' src/unity-ratings-db.c || true
    sed -i '/#if DB_VERSION_MAJOR != 5/,/#endif/d' src/unity-ratings-db.c || true

    autoreconf -fiv
}

build() {
    cd "$srcdir"
    ./configure \
        --prefix=/usr \
        --sysconfdir=/etc \
        --disable-static
    make
}

package() {
    cd "$srcdir"
    make DESTDIR="$pkgdir" install
    find "$pkgdir" -name '*.la' -delete
}
