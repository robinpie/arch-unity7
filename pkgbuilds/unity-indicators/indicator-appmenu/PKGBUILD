# Maintainer: arch-unity7 port
# Upstream: https://launchpad.net/indicator-appmenu

pkgname=indicator-appmenu
pkgver=15.02.0
_uver=+20.10.20260311
_urev=0ubuntu1
pkgrel=1
pkgdesc="Indicator for application menus used by the Unity7 user interface"
arch=('x86_64')
url="https://launchpad.net/indicator-appmenu"
license=('GPL-3.0-or-later')
depends=(
    'glib2'
    'libdbusmenu-gtk3'
    'libindicator-gtk3'
    'bamf'
    'gtk3'
    'dconf'
    'libx11'
    'appmenu-gtk-module'
)
makedepends=(
    'pkgconf'
    'libappindicator'
    'gnome-common'
    'indicator-application'
    'intltool'
    'gtk-doc'
    'autoconf'
    'automake'
    'libtool'
)
source=(
    "https://launchpad.net/ubuntu/+archive/primary/+files/${pkgname}_${pkgver}${_uver}-${_urev}.tar.gz"
)
sha256sums=('SKIP')

prepare() {
    cd "${pkgname}.git"

    # Fix ",: command not found" error
    sed -i "/BUILD_CLI/{s/,$//}" configure.ac || true

    autoreconf -fiv
}

build() {
    cd "${pkgname}.git"
    ./configure \
        --prefix=/usr \
        --sysconfdir=/etc \
        --disable-static
    make
}

package() {
    cd "${pkgname}.git"
    make DESTDIR="$pkgdir" install
    find "$pkgdir" -name '*.la' -delete
}
