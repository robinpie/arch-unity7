install-dist_indicatorDATA: $(dist_indicator_DATA)
	@$(NORMAL_INSTALL)
	@list='$(dist_indicator_DATA)'; test -n "$(indicatordir)" || list=; \
	if test -n "$$list"; then \
	  echo " $(MKDIR_P) '$(DESTDIR)$(indicatordir)'"; \
	  $(MKDIR_P) "$(DESTDIR)$(indicatordir)" || exit 1; \
	fi; \
	for p in $$list; do \
	  if test -f "$$p"; then d=; else d="$(srcdir)/"; fi; \
	  echo "$$d$$p"; \
	done | $(am__base_list) | \
	while read files; do \
	  echo " $(INSTALL_DATA) $$files '$(DESTDIR)$(indicatordir)'"; \
	  $(INSTALL_DATA) $$files "$(DESTDIR)$(indicatordir)" || exit $$?; \
	done

uninstall-dist_indicatorDATA:
	@$(NORMAL_UNINSTALL)
	@list='$(dist_indicator_DATA)'; test -n "$(indicatordir)" || list=; \
	files=`for p in $$list; do echo $$p; done | sed -e 's|^.*/||'`; \
	dir='$(DESTDIR)$(indicatordir)'; $(am__uninstall_files_from_dir)
