$(builddir)/main.c: $(builddir)/indicator_keyboard_icon_generator_vala.stamp
	@if test ! -f $@ && test $(srcdir) != $(builddir) && test -n "$$(find -L $(srcdir)/main.vala -prune ! -newer $(srcdir)/main.c)"; then cp -p $(srcdir)/main.c $(builddir)/main.c; fi
	@if test -f $@; then :; else rm -f $(builddir)/indicator_keyboard_icon_generator_vala.stamp; fi
	@if test -f $@; then :; else \
	  $(MAKE) $(AM_MAKEFLAGS) $(builddir)/indicator_keyboard_icon_generator_vala.stamp; \
	  if test $(builddir) != .; then mv main.c $(builddir)/; fi \
	fi
$(builddir)/$(top_srcdir)/lib/common.c: $(builddir)/indicator_keyboard_icon_generator_vala.stamp
	@if test ! -f $@ && test $(srcdir) != $(builddir) && test -n "$$(find -L $(srcdir)/$(top_srcdir)/lib/common.vala -prune ! -newer $(srcdir)/$(top_srcdir)/lib/common.c)"; then cp -p $(srcdir)/$(top_srcdir)/lib/common.c $(builddir)/$(top_srcdir)/lib/common.c; fi
	@if test -f $@; then :; else rm -f $(builddir)/indicator_keyboard_icon_generator_vala.stamp; fi
	@if test -f $@; then :; else \
	  $(MAKE) $(AM_MAKEFLAGS) $(builddir)/indicator_keyboard_icon_generator_vala.stamp; \
	  if test $(builddir)/$(top_srcdir)/lib != .; then mv common.c $(builddir)/$(top_srcdir)/lib/; fi \
	fi
$(builddir)/indicator_keyboard_icon_generator_vala.stamp: main.vala $(top_srcdir)/lib/common.vala
	$(AM_V_at)rm -f $@ && echo stamp > $@-t
	$(AM_V_VALAC)$(VALAC) $(indicator_keyboard_icon_generator_VALAFLAGS) $(VALAFLAGS) -C $^
	$(AM_V_at)mv -f $@-t $@

mostlyclean-libtool:
	-rm -f *.lo

clean-libtool:
	-rm -rf .libs _libs
install-dist_indicatorDATA: $(dist_indicator_DATA)
	@$(NORMAL_INSTALL)
	@list='$(dist_indicator_DATA)'; test -n "$(indicatordir)" || list=; \
	if test -n "$$list"; then \
	  echo " $(MKDIR_P) '$(DESTDIR)$(indicatordir)'"; \
	  $(MKDIR_P) "$(DESTDIR)$(indicatordir)" || exit 1; \
	fi; \
	for p in $$list; do \
	  if test -f "$$p"; then d=; else d="$(srcdir)/"; fi; \
	  echo "$$d$$p"; \
	done | $(am__base_list) | \
	while read files; do \
	  echo " $(INSTALL_DATA) $$files '$(DESTDIR)$(indicatordir)'"; \
	  $(INSTALL_DATA) $$files "$(DESTDIR)$(indicatordir)" || exit $$?; \
	done

uninstall-dist_indicatorDATA:
	@$(NORMAL_UNINSTALL)
	@list='$(dist_indicator_DATA)'; test -n "$(indicatordir)" || list=; \
	files=`for p in $$list; do echo $$p; done | sed -e 's|^.*/||'`; \
	dir='$(DESTDIR)$(indicatordir)'; $(am__uninstall_files_from_dir)
install-systemdDATA: $(systemd_DATA)
	@$(NORMAL_INSTALL)
	@list='$(systemd_DATA)'; test -n "$(systemddir)" || list=; \
	if test -n "$$list"; then \
	  echo " $(MKDIR_P) '$(DESTDIR)$(systemddir)'"; \
	  $(MKDIR_P) "$(DESTDIR)$(systemddir)" || exit 1; \
	fi; \
	for p in $$list; do \
	  if test -f "$$p"; then d=; else d="$(srcdir)/"; fi; \
	  echo "$$d$$p"; \
	done | $(am__base_list) | \
	while read files; do \
	  echo " $(INSTALL_DATA) $$files '$(DESTDIR)$(systemddir)'"; \
	  $(INSTALL_DATA) $$files "$(DESTDIR)$(systemddir)" || exit $$?; \
	done

uninstall-systemdDATA:
	@$(NORMAL_UNINSTALL)
	@list='$(systemd_DATA)'; test -n "$(systemddir)" || list=; \
	files=`for p in $$list; do echo $$p; done | sed -e 's|^.*/||'`; \
	dir='$(DESTDIR)$(systemddir)'; $(am__uninstall_files_from_dir)
