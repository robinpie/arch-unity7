	@echo "it deletes files that may require special tools to rebuild."
	-$(am__rm_f) $(builddir)/indicator_keyboard_icon_generator_vala.stamp
	-$(am__rm_f) $(srcdir)/$(top_srcdir)/lib/common.c
	-$(am__rm_f) $(srcdir)/main.c
	-$(am__rm_f) $(top_srcdir)/lib/common.c
	-$(am__rm_f) main.c
