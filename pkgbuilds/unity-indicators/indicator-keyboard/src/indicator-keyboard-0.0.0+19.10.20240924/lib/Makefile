$(builddir)/main.c: $(builddir)/indicator_keyboard_service_vala.stamp
	@if test ! -f $@ && test $(srcdir) != $(builddir) && test -n "$$(find -L $(srcdir)/main.vala -prune ! -newer $(srcdir)/main.c)"; then cp -p $(srcdir)/main.c $(builddir)/main.c; fi
	@if test -f $@; then :; else rm -f $(builddir)/indicator_keyboard_service_vala.stamp; fi
	@if test -f $@; then :; else \
	  $(MAKE) $(AM_MAKEFLAGS) $(builddir)/indicator_keyboard_service_vala.stamp; \
	  if test $(builddir) != .; then mv main.c $(builddir)/; fi \
	fi
