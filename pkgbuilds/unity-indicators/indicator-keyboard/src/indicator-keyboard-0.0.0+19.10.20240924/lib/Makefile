	@rm -f indicator-keyboard-service$(EXEEXT)
	$(AM_V_CCLD)$(indicator_keyboard_service_LINK) $(indicator_keyboard_service_OBJECTS) $(indicator_keyboard_service_LDADD) $(LIBS)

