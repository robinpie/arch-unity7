clean-generic:

distclean-generic:
	-$(am__rm_f) $(CONFIG_CLEAN_FILES)
	-test . = "$(srcdir)" || $(am__rm_f) $(CONFIG_CLEAN_VPATH_FILES)
	-$(am__rm_f) $(builddir)/config.c
	-$(am__rm_f) $(builddir)/fixture.c
	-$(am__rm_f) $(builddir)/main.c

maintainer-clean-generic:
	@echo "This command is intended for maintainers to use"
	@echo "it deletes files that may require special tools to rebuild."
	-$(am__rm_f) $(builddir)/indicator_keyboard_tests_vala.stamp
	-$(am__rm_f) $(srcdir)/config.c
	-$(am__rm_f) $(srcdir)/fixture.c
	-$(am__rm_f) $(srcdir)/main.c
	-$(am__rm_f) config.c
	-$(am__rm_f) fixture.c
	-$(am__rm_f) main.c
