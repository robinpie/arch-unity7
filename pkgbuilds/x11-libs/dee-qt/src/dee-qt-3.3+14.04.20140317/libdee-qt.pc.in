prefix=@PREFIX@
exec_prefix=@EXEC_PREFIX@
libdir=${exec_prefix}/@CMAKE_LIBRARY_ARCHITECTURE@
includedir=${prefix}/@INCLUDE_INSTALL_DIR@

Name: @DEE_QT_LIBNAME@
Description: Qt binding and QML plugin for Dee.
Version: @VERSION@

Requires: @QT_PKGCONFIG_DEPENDENCIES@ dee-1.0
Libs: -L${libdir} -l@DEE_QT_LIBNAME@
Cflags: -I${includedir}
