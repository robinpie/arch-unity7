	cd /run/media/robin/robinScard/codingStuff/arch-unity7/pkgbuilds/unity-base/hud/src/build && $(MAKE) $(MAKESILENT) -f libhud/CMakeFiles/hud-generated.dir/build.make libhud/CMakeFiles/hud-generated.dir/service-iface.c.o
.PHONY : service-iface.c.o

service-iface.i: service-iface.c.i
.PHONY : service-iface.i

# target to preprocess a source file
service-iface.c.i:
	cd /run/media/robin/robinScard/codingStuff/arch-unity7/pkgbuilds/unity-base/hud/src/build && $(MAKE) $(MAKESILENT) -f libhud/CMakeFiles/hud-generated.dir/build.make libhud/CMakeFiles/hud-generated.dir/service-iface.c.i
.PHONY : service-iface.c.i

service-iface.s: service-iface.c.s
.PHONY : service-iface.s

# target to generate assembly for a file
service-iface.c.s:
