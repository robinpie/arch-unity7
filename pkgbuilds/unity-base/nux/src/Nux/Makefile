	$(AM_V_CXXLD)$(libnux_4.0_la_LINK) -rpath $(libdir) $(libnux_4.0_la_OBJECTS) $(libnux_4.0_la_LIBADD) $(LIBS)

mostlyclean-compile:
	-rm -f *.$(OBJEXT)

distclean-compile:
	-rm -f *.tab.c

