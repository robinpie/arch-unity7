@BUILD_TESTS_TRUE@CHECK_GTEST_OPTIONS = 

# Disable EmbeddedContext tests when OpenGLES is enabled, they tend to crash
@BUILD_TESTS_TRUE@@NUX_OPENGLES_20_TRUE@CHECK_GTEST_OPTIONS = --gtest_filter=-EmbeddedContext*
@BUILD_TESTS_TRUE@CLEANFILES = \
@BUILD_TESTS_TRUE@	test-nux-results.xml test-nux-results.html \
@BUILD_TESTS_TRUE@	gtest-nux-results.xml

unused_src = \
 manual-tests/linaro-reference-fbo.txt \
 manual-tests/text-entry.txt \
 test-canvas.cpp \
 test-nux.cpp \
 test-system.cpp \
 test-timeline.cpp \
 xim-test-commands.txt

EXTRA_DIST = Readme.txt ${unused_src}
all: all-am

.SUFFIXES:
.SUFFIXES: .cc .cpp .lo .o .obj
$(srcdir)/Makefile.in:  $(srcdir)/Makefile.am  $(am__configure_deps)
	@for dep in $?; do \
	  case '$(am__configure_deps)' in \
	    *$$dep*) \
	      ( cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh ) \
	        && { if test -f $@; then exit 0; else break; fi; }; \
	      exit 1;; \
	  esac; \
	done; \
	echo ' cd $(top_srcdir) && $(AUTOMAKE) --gnu tests/Makefile'; \
	$(am__cd) $(top_srcdir) && \
	  $(AUTOMAKE) --gnu tests/Makefile
Makefile: $(srcdir)/Makefile.in $(top_builddir)/config.status
	@case '$?' in \
	  *config.status*) \
	    cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh;; \
	  *) \
	    echo ' cd $(top_builddir) && $(SHELL) ./config.status $(subdir)/$@ $(am__maybe_remake_depfiles)'; \
	    cd $(top_builddir) && $(SHELL) ./config.status $(subdir)/$@ $(am__maybe_remake_depfiles);; \
	esac;

$(top_builddir)/config.status: $(top_srcdir)/configure $(CONFIG_STATUS_DEPENDENCIES)
	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh

$(top_srcdir)/configure:  $(am__configure_deps)
	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh
$(ACLOCAL_M4):  $(am__aclocal_m4_deps)
	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh
$(am__aclocal_m4_deps):

clean-checkPROGRAMS:
	$(am__rm_f) $(check_PROGRAMS)
	test -z "$(EXEEXT)" || $(am__rm_f) $(check_PROGRAMS:$(EXEEXT)=)

clean-checkLIBRARIES:
	-$(am__rm_f) $(check_LIBRARIES)

libgtest.a: $(libgtest_a_OBJECTS) $(libgtest_a_DEPENDENCIES) $(EXTRA_libgtest_a_DEPENDENCIES) 
	$(AM_V_at)-rm -f libgtest.a
	$(AM_V_AR)$(libgtest_a_AR) libgtest.a $(libgtest_a_OBJECTS) $(libgtest_a_LIBADD)
	$(AM_V_at)$(libgtest_a_RANLIB) libgtest.a

gtest-nux$(EXEEXT): $(gtest_nux_OBJECTS) $(gtest_nux_DEPENDENCIES) $(EXTRA_gtest_nux_DEPENDENCIES) 
	@rm -f gtest-nux$(EXEEXT)
	$(AM_V_CXXLD)$(CXXLINK) $(gtest_nux_OBJECTS) $(gtest_nux_LDADD) $(LIBS)

gtest-nux-slow$(EXEEXT): $(gtest_nux_slow_OBJECTS) $(gtest_nux_slow_DEPENDENCIES) $(EXTRA_gtest_nux_slow_DEPENDENCIES) 
	@rm -f gtest-nux-slow$(EXEEXT)
	$(AM_V_CXXLD)$(gtest_nux_slow_LINK) $(gtest_nux_slow_OBJECTS) $(gtest_nux_slow_LDADD) $(LIBS)

gtest-nuxcore$(EXEEXT): $(gtest_nuxcore_OBJECTS) $(gtest_nuxcore_DEPENDENCIES) $(EXTRA_gtest_nuxcore_DEPENDENCIES) 
