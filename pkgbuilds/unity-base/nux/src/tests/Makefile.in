#run make test as part of make check
@BUILD_TESTS_TRUE@check-local: test gtest test-apps

@BUILD_TESTS_TRUE@test:
@BUILD_TESTS_TRUE@	@gtester --verbose -k -o=gtest-nux-results.xml ./gtest-nux

@BUILD_TESTS_TRUE@gtest-build: gtest-nuxcore gtest-nuxgraphics gtest-nux gtest-nux-slow

@BUILD_TESTS_TRUE@gtest: gtest-build
@BUILD_TESTS_TRUE@	./gtest-nuxcore
@BUILD_TESTS_TRUE@	./gtest-nuxgraphics
@BUILD_TESTS_TRUE@	./gtest-nux
@BUILD_TESTS_TRUE@	./gtest-nux-slow

@BUILD_TESTS_TRUE@check-headless: gtest-nuxcore gtest-nuxgraphics gtest-nux gtest-nux-slow
@BUILD_TESTS_TRUE@	@./gtest-nuxcore --gtest_output=xml:./test-nux-core-results.xml $(CHECK_GTEST_OPTIONS)
@BUILD_TESTS_TRUE@	@./dummy-xorg-test-runner.sh ./gtest-nuxgraphics --gtest_output=xml:./test-nux-graphics-results.xml $(CHECK_GTEST_OPTIONS)
@BUILD_TESTS_TRUE@	@./dummy-xorg-test-runner.sh ./gtest-nux --gtest_output=xml:./test-nux-results.xml $(CHECK_GTEST_OPTIONS)
@BUILD_TESTS_TRUE@	@./dummy-xorg-test-runner.sh ./gtest-nux-slow --gtest_output=xml:./test-nux-slow-results.xml $(CHECK_GTEST_OPTIONS)

@BUILD_TESTS_TRUE@check: gtest-nuxcore gtest-nuxgraphics gtest-nux gtest-nux-slow
@BUILD_TESTS_TRUE@	@./gtest-nuxcore --gtest_output=xml:./test-nux-core-results.xml
@BUILD_TESTS_TRUE@	@./gtest-nuxgraphics --gtest_output=xml:./test-nux-graphics-results.xml
@BUILD_TESTS_TRUE@	@./gtest-nux --gtest_output=xml:./test-nux-results.xml
@BUILD_TESTS_TRUE@	@./gtest-nux-slow --gtest_output=xml:./test-nux-slow-results.xml

@BUILD_TESTS_TRUE@test-apps: test-graphics-display test-empty-window xtest-text-entry-xim xtest-text-entry xtest-button xtest-mouse-events xtest-mouse-buttons xtest-hgrid-key-navigation xtest-hlayout-key-navigation xtest-vlayout-key-navigation xtest-scrollbar xtest-focus-on-mouse-down xtest-focus-on-mouse-enter xtest-keynav-directions xtest-text-entry-logic xtest-text-entry-deadkeys xtest-text-entry-compositionkeys
@BUILD_TESTS_TRUE@	./test-graphics-display
@BUILD_TESTS_TRUE@	./test-empty-window
@BUILD_TESTS_TRUE@	./xtest-text-entry
@BUILD_TESTS_TRUE@	./xtest-button
@BUILD_TESTS_TRUE@	./xtest-mouse-events
@BUILD_TESTS_TRUE@	./xtest-mouse-buttons
@BUILD_TESTS_TRUE@	./xtest-hgrid-key-navigation
@BUILD_TESTS_TRUE@	./xtest-hlayout-key-navigation
@BUILD_TESTS_TRUE@	./xtest-vlayout-key-navigation
@BUILD_TESTS_TRUE@	./xtest-scrollbar
@BUILD_TESTS_TRUE@	./xtest-focus-on-mouse-down
@BUILD_TESTS_TRUE@	./xtest-focus-on-mouse-enter
