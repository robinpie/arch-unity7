@BUILD_TESTS_TRUE@nodist_libgtest_a_SOURCES = \
@BUILD_TESTS_TRUE@ $(GMOCK_PREFIX)/src/gmock-all.cc \
@BUILD_TESTS_TRUE@ $(GTEST_PREFIX)/src/gtest-all.cc

@BUILD_TESTS_TRUE@libgtest_a_CPPFLAGS = $(GMOCK_CPPFLAGS) $(GTEST_CPPFLAGS) -w
@BUILD_TESTS_TRUE@check_LIBRARIES = libgtest.a
@BUILD_TESTS_TRUE@TestFlags = -I$(srcdir) \
@BUILD_TESTS_TRUE@            -I$(top_srcdir) \
@BUILD_TESTS_TRUE@            -DPREFIX=\""$(prefix)"\" \
@BUILD_TESTS_TRUE@            -DLIBDIR=\""$(libdir)"\" \
@BUILD_TESTS_TRUE@            -DDATADIR=\""$(datadir)"\" \
@BUILD_TESTS_TRUE@            -DG_LOG_DOMAIN=\"NuxTests\" \
@BUILD_TESTS_TRUE@            -DTESTDIR=\""$(top_srcdir)/tests"\" \
@BUILD_TESTS_TRUE@            $(GCC_TESTS_FLAGS) \
@BUILD_TESTS_TRUE@            $(NUX_CORE_CFLAGS) \
@BUILD_TESTS_TRUE@            $(NUX_EXAMPLES_CFLAGS) \
@BUILD_TESTS_TRUE@            $(NUX_CFLAGS) \
@BUILD_TESTS_TRUE@            $(NUX_TESTS_CFLAGS) \
@BUILD_TESTS_TRUE@            $(MAINTAINER_CFLAGS) \
@BUILD_TESTS_TRUE@            $(IBUS_CFLAGS) \
@BUILD_TESTS_TRUE@            $(GEIS_CFLAGS)

@BUILD_TESTS_TRUE@TestLibs = $(top_builddir)/NuxCore/libnux-core-@NUX_API_VERSION@.la \
@BUILD_TESTS_TRUE@           $(top_builddir)/NuxGraphics/libnux-graphics-@NUX_API_VERSION@.la \
@BUILD_TESTS_TRUE@           $(top_builddir)/Nux/libnux-@NUX_API_VERSION@.la \
@BUILD_TESTS_TRUE@           $(NUX_TESTS_LIBS) \
@BUILD_TESTS_TRUE@           $(NUX_LIBS)

@BUILD_TESTS_TRUE@GTestFlags = $(TestFlags) \
@BUILD_TESTS_TRUE@             $(GMOCK_CPPFLAGS) \
@BUILD_TESTS_TRUE@             $(GTEST_CPPFLAGS)

@BUILD_TESTS_TRUE@GTestLibs = $(TestLibs) \
@BUILD_TESTS_TRUE@            libgtest.a

@BUILD_TESTS_TRUE@GTestLDFlags = -lboost_system \
@BUILD_TESTS_TRUE@               -lboost_filesystem


