@BUILD_TESTS_TRUE@check-report:
@BUILD_TESTS_TRUE@	@gtester -k -o=test-nux-results.xml -k ./test-nux \
@BUILD_TESTS_TRUE@		&& ( gtester-report test-nux-results.xml \
@BUILD_TESTS_TRUE@				| sed 's/GTester Unit Test Report</>GTester Unit Test Report (normal)</' \
@BUILD_TESTS_TRUE@				> test-nux-results.html ) \
@BUILD_TESTS_TRUE@		&& gnome-open ./test-nux-results.html

@BUILD_TESTS_TRUE@full-report:
@BUILD_TESTS_TRUE@	@gtester -k -o=test-nux-results.xml -k -m=slow ./test-nux \
@BUILD_TESTS_TRUE@	  && ( gtester-report test-nux-results.xml \
@BUILD_TESTS_TRUE@	      | sed 's/>GTester Unit Test Report</>GTester Unit Test Report (normal)</' \
@BUILD_TESTS_TRUE@	      > test-nux-results.html )

@BUILD_TESTS_TRUE@.PHONY: check check-report full-report gtest test check-headless

