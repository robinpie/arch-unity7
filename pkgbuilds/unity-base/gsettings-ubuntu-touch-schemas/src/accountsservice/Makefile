	@$(NORMAL_INSTALL)
	@list='$(dist_pkla_DATA)'; test -n "$(pkladir)" || list=; \
	if test -n "$$list"; then \
	  echo " $(MKDIR_P) '$(DESTDIR)$(pkladir)'"; \
	  $(MKDIR_P) "$(DESTDIR)$(pkladir)" || exit 1; \
	fi; \
	for p in $$list; do \
	  if test -f "$$p"; then d=; else d="$(srcdir)/"; fi; \
	  echo "$$d$$p"; \
	done | $(am__base_list) | \
	while read files; do \
	  echo " $(INSTALL_DATA) $$files '$(DESTDIR)$(pkladir)'"; \
	  $(INSTALL_DATA) $$files "$(DESTDIR)$(pkladir)" || exit $$?; \
	done

