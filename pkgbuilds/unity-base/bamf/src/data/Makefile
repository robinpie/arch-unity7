installdirs:
	for dir in "$(DESTDIR)$(bamfdaemondbusrunnerdir)" "$(DESTDIR)$(servicedir)" "$(DESTDIR)$(systemddir)" "$(DESTDIR)$(upstartdir)"; do \
	  test -z "$$dir" || $(MKDIR_P) "$$dir"; \
	done
