+Build-Depends: dbus (>= 1.8),
+               debhelper (>= 9),
+               dh-autoreconf,
+               dpkg-dev (>= 1.22.5),
+               gnome-common,
+               gobject-introspection (>= 1.41.4-1~),
+               gtk-doc-tools,
+               hicolor-icon-theme,
+               libdbusmenu-gtk3-dev,
+               libglib2.0-dev (>= 2.32.0),
+               libgtop2-dev,
