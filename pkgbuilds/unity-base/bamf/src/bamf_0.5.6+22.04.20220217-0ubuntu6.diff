--- bamf-0.5.6+22.04.20220217.orig/debian/bamfdaemon.postrm
+++ bamf-0.5.6+22.04.20220217/debian/bamfdaemon.postrm
@@ -0,0 +1,8 @@
+#! /bin/sh
