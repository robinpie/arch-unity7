	-rm -f ./$(DEPDIR)/libmedia_keys_la-dialog-window.Plo
	-rm -f ./$(DEPDIR)/libmedia_keys_la-gsd-marshal.Plo
	-rm -f ./$(DEPDIR)/libmedia_keys_la-gsd-media-keys-manager.Plo
	-rm -f ./$(DEPDIR)/libmedia_keys_la-gsd-media-keys-plugin.Plo
	-rm -f ./$(DEPDIR)/libmedia_keys_la-gsd-screenshot-utils.Plo
	-rm -f ./$(DEPDIR)/libmedia_keys_la-pa-backend.Plo
	-rm -f ./$(DEPDIR)/libmedia_keys_la-shell-key-grabber.Plo
	-rm -f Makefile
distclean-am: clean-am distclean-compile distclean-generic \
	distclean-tags

