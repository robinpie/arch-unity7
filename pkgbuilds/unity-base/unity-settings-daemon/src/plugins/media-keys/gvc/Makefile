	$(AM_V_at)$(am__mv) $(DEPDIR)/libgvc_la-gvc-mixer-card.Tpo $(DEPDIR)/libgvc_la-gvc-mixer-card.Plo
#	$(AM_V_CC)source='gvc-mixer-card.c' object='libgvc_la-gvc-mixer-card.lo' libtool=yes \
