prefix=/usr
exec_prefix=${prefix}
libdir=/usr/lib
includedir=${prefix}/include
libexecdir=/usr/libexec
plugindir=${libdir}/unity-settings-daemon-1.0
binary=${libexecdir}/unity-settings-daemon

Name: unity-settings-daemon
Description: Utility library for accessing unity-settings-daemon over DBUS
Requires: glib-2.0
Version: 1.0
Libs: -L${libdir}
Cflags: -I${includedir}/unity-settings-daemon-1.0
