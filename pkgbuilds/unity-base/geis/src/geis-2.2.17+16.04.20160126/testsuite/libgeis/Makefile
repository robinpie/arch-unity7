$(srcdir)/Makefile.in:  $(srcdir)/Makefile.am  $(am__configure_deps)
	@for dep in $?; do \
	  case '$(am__configure_deps)' in \
	    *$$dep*) \
	      ( cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh ) \
	        && { if test -f $@; then exit 0; else break; fi; }; \
	      exit 1;; \
	  esac; \
	done; \
	echo ' cd $(top_srcdir) && $(AUTOMAKE) --gnu testsuite/libgeis/Makefile'; \
	$(am__cd) $(top_srcdir) && \
	  $(AUTOMAKE) --gnu testsuite/libgeis/Makefile
Makefile: $(srcdir)/Makefile.in $(top_builddir)/config.status
	@case '$?' in \
	  *config.status*) \
	    cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh;; \
	  *) \
	    echo ' cd $(top_builddir) && $(SHELL) ./config.status $(subdir)/$@ $(am__maybe_remake_depfiles)'; \
	    cd $(top_builddir) && $(SHELL) ./config.status $(subdir)/$@ $(am__maybe_remake_depfiles);; \
	esac;

$(top_builddir)/config.status: $(top_srcdir)/configure $(CONFIG_STATUS_DEPENDENCIES)
	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh

$(top_srcdir)/configure:  $(am__configure_deps)
	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh
$(ACLOCAL_M4):  $(am__aclocal_m4_deps)
	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh
$(am__aclocal_m4_deps):

clean-checkPROGRAMS:
	$(am__rm_f) $(check_PROGRAMS)
	test -z "$(EXEEXT)" || $(am__rm_f) $(check_PROGRAMS:$(EXEEXT)=)

check-c-compile$(EXEEXT): $(check_c_compile_OBJECTS) $(check_c_compile_DEPENDENCIES) $(EXTRA_check_c_compile_DEPENDENCIES) 
	@rm -f check-c-compile$(EXEEXT)
	$(AM_V_CCLD)$(LINK) $(check_c_compile_OBJECTS) $(check_c_compile_LDADD) $(LIBS)

check-cxx-compile$(EXEEXT): $(check_cxx_compile_OBJECTS) $(check_cxx_compile_DEPENDENCIES) $(EXTRA_check_cxx_compile_DEPENDENCIES) 
	@rm -f check-cxx-compile$(EXEEXT)
	$(AM_V_CXXLD)$(CXXLINK) $(check_cxx_compile_OBJECTS) $(check_cxx_compile_LDADD) $(LIBS)

check_geis2_internals$(EXEEXT): $(check_geis2_internals_OBJECTS) $(check_geis2_internals_DEPENDENCIES) $(EXTRA_check_geis2_internals_DEPENDENCIES) 
	@rm -f check_geis2_internals$(EXEEXT)
	$(AM_V_CCLD)$(LINK) $(check_geis2_internals_OBJECTS) $(check_geis2_internals_LDADD) $(LIBS)

