install-geisviewPYTHON: $(geisview_PYTHON)
	@$(NORMAL_INSTALL)
	@list='$(geisview_PYTHON)'; dlist=; list2=; test -n "$(geisviewdir)" || list=; \
	if test -n "$$list"; then \
	  echo " $(MKDIR_P) '$(DESTDIR)$(geisviewdir)'"; \
	  $(MKDIR_P) "$(DESTDIR)$(geisviewdir)" || exit 1; \
	fi; \
	for p in $$list; do \
	  if test -f "$$p"; then b=; else b="$(srcdir)/"; fi; \
	  if test -f $$b$$p; then \
	    $(am__strip_dir) \
	    dlist="$$dlist $$f"; \
	    list2="$$list2 $$b$$p"; \
	  else :; fi; \
	done; \
	for file in $$list2; do echo $$file; done | $(am__base_list) | \
	while read files; do \
	  echo " $(INSTALL_DATA) $$files '$(DESTDIR)$(geisviewdir)'"; \
	  $(INSTALL_DATA) $$files "$(DESTDIR)$(geisviewdir)" || exit $$?; \
	done || exit $$?; \
	if test -n "$$dlist"; then \
	  $(am__py_compile) --destdir "$(DESTDIR)" \
	                    --basedir "$(geisviewdir)" $$dlist; \
	else :; fi

uninstall-geisviewPYTHON:
	@$(NORMAL_UNINSTALL)
	@list='$(geisview_PYTHON)'; test -n "$(geisviewdir)" || list=; \
	py_files=`for p in $$list; do echo $$p; done | sed -e 's|^.*/||'`; \
	test -n "$$py_files" || exit 0; \
	dir='$(DESTDIR)$(geisviewdir)'; \
	pyc_files=`echo "$$py_files" | sed 's|$$|c|'`; \
	pyo_files=`echo "$$py_files" | sed 's|$$|o|'`; \
	st=0; \
	for files in "$$py_files" "$$pyc_files" "$$pyo_files"; do \
	  $(am__uninstall_files_from_dir) || st=$$?; \
	done; \
	dir='$(DESTDIR)$(geisviewdir)'; \
	files=`echo "$$py_files" | $(am__pep3147_tweak)`; \
	$(am__uninstall_files_from_dir) || st=$$?; \
	exit $$st
