	@$(NORMAL_UNINSTALL)
	@list='$(dist_xdg_DATA)'; test -n "$(xdgdir)" || list=; \
	files=`for p in $$list; do echo $$p; done | sed -e 's|^.*/||'`; \
	dir='$(DESTDIR)$(xdgdir)'; $(am__uninstall_files_from_dir)
