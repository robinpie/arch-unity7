				<option type="float" name="display_time">
					<short>Display Time</short>
					<short xml:lang="uk">Показ часу</short>
					<long>Timeout of the workspacename display (in seconds).</long>
					<min>0.1</min>
					<max>5.0</max>
					<precision>0.05</precision>
					<default>1.5</default>
				</option>
