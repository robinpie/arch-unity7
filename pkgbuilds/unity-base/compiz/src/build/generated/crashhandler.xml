<?xml version="1.0" encoding="UTF-8"?>
<compiz>
	<plugin useBcop="true" name="crashhandler">
		<short>Crash handler</short>
		<short xml:lang="da">Nedbrudshåndtering</short>
		<short xml:lang="uk">Обробник збоїв</short>
		<long>Compiz crash handler plugin</long>
		<long xml:lang="uk">Втулок Compiz Crash Handler</long>
		<category>Utility</category>
		<options>
			<group>
				<short>Main</short>
				<short xml:lang="uk">Головне</short>
				<option type="bool" name="enabled">
					<short>Enable Crash Handler</short>
					<short xml:lang="uk">Увімкнути попереджувач зависання</short>
					<long>Activate Crash Handler.</long>
					<long xml:lang="uk">Увімкнути Crash Handler</long>
					<default>true</default>
				</option>
				<option type="string" name="directory">
					<short>Crash Dump Directory</short>
					<short xml:lang="uk">Тека дампів пам'яти при зависанні</short>
					<long>Directory to dump the crash logs to.</long>
					<long xml:lang="uk">Тека для логфайлів при зависанні.</long>
					<hints>directory;</hints>
					<default>/tmp</default>
				</option>
				<option type="bool" name="start_wm">
					<short>Start Other Window Manager</short>
					<short xml:lang="uk">Вмикати инший Упорядник Вікон.</short>
					<long>Start other window manager on Crash.</long>
					<long xml:lang="uk">Вмикати инший Упорядник Вікон при зависанні.</long>
					<default>false</default>
				</option>
				<option type="string" name="wm_cmd">
					<short>Window Manager Command Line</short>
					<short xml:lang="uk">Командний рядок Упорядника вікон.</short>
					<long>Window manager command line. DO NOT ENTER COMPIZ HERE!!!</long>
					<long xml:lang="uk">Командний рядок кпорядника вікон. НЕ ЗАХОДЬТЕ СЮДОЮ В COMPIZ!!!</long>
					<hints>command;</hints>
					<default/>
				</option>
			</group>
		</options>
	</plugin>
</compiz>