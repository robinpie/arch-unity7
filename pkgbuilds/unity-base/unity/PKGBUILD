# Upstream: https://launchpad.net/unity

pkgname=unity
pkgver=7.7.1
_uver=+26.04.20260306
_urev=0ubuntu2
pkgrel=1
pkgdesc="The Ubuntu Unity Desktop"
arch=('x86_64')
url="https://launchpad.net/unity"
license=('GPL-3.0-or-later' 'LGPL-3.0-or-later')
depends=(
    'at-spi2-core'
    'appstream'
    'dee'
    'glib2'
