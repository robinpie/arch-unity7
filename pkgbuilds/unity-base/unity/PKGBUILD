)
source=(
    "https://launchpad.net/ubuntu/+archive/primary/+files/${pkgname}_${pkgver}${_uver}-${_urev}.tar.xz"
    "add-unity-version-xml.patch"
    "nemo-support.patch"
    "revert-unwanted-ubuntu-unity-changes.patch"
    "remove-all-code-related-to-online-search.patch"
    "prevent-compiz-segfault-by-guarding-pthread_join.patch"
    "dash-and-hud-border-fixes.patch"
    "transparent-panel-fixes.patch"
    # branding
    "launcher_bfb.svg"
    "lockscreen_cof.png"
    # resources
    "dash_bottom_border_tile.png"
    "dash_bottom_left_corner.png"
    "dash_bottom_left_corner_mask.png"
    "dash_bottom_right_corner.png"
    "dash_left_tile.png"
    "dash_right_border_tile.png"
    "dash_top_edge.png"
    "dash_top_right_corner.png"
    "dash_top_right_corner_mask.png"
    "dash_top_tile.png"
    # session scripts
    "70im-config"
