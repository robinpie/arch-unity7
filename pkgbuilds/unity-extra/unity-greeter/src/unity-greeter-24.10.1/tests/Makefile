$(builddir)/test.c: $(builddir)/unity_greeter_test_vala.stamp
	@if test ! -f $@ && test $(srcdir) != $(builddir) && test -n "$$(find -L $(srcdir)/test.vala -prune ! -newer $(srcdir)/test.c)"; then cp -p $(srcdir)/test.c $(builddir)/test.c; fi
	@if test -f $@; then :; else rm -f $(builddir)/unity_greeter_test_vala.stamp; fi
	@if test -f $@; then :; else \
	  $(MAKE) $(AM_MAKEFLAGS) $(builddir)/unity_greeter_test_vala.stamp; \
	  if test $(builddir) != .; then mv test.c $(builddir)/; fi \
	fi
$(builddir)/test-list.c: $(builddir)/unity_greeter_test_vala.stamp
	@if test ! -f $@ && test $(srcdir) != $(builddir) && test -n "$$(find -L $(srcdir)/test-list.vala -prune ! -newer $(srcdir)/test-list.c)"; then cp -p $(srcdir)/test-list.c $(builddir)/test-list.c; fi
	@if test -f $@; then :; else rm -f $(builddir)/unity_greeter_test_vala.stamp; fi
