#: ../src/greeter-list.vala:302
#, c-format
msgid "Enter password for %s"
msgstr "Sekcem awal uffir i %s"

#: ../src/greeter-list.vala:807 ../src/user-list.vala:701
msgid "Password:"
msgstr "Awal uffir:"

#: ../src/greeter-list.vala:809 ../src/user-list.vala:695
msgid "Username:"
msgstr "Isem n useqdac:"

#: ../src/greeter-list.vala:864
msgid "Invalid password, please try again"
msgstr "Yir awal uffir, ttxilek ɛṛeḍ tikelt nniḍen"

#: ../src/greeter-list.vala:875
msgid "Failed to authenticate"
msgstr "Tucḍa deg usentem"

#: ../src/greeter-list.vala:921
msgid "Failed to start session"
msgstr "Tuccḍa i beddu n tγimit"

#: ../src/greeter-list.vala:936
msgid "Logging in…"
msgstr "Tuqqna tetteddu..."

#: ../src/main-window.vala:49
msgid "Login Screen"
msgstr "Agdil n tuqqna"

#: ../src/main-window.vala:118
msgid "Back"
msgstr "Tuγalin"

#: ../src/menubar.vala:220
msgid "Onscreen keyboard"
msgstr "Anasiw γef ugdil"

#: ../src/menubar.vala:225
msgid "High Contrast"
msgstr "Amyeẓli afellay"

#: ../src/menubar.vala:231
msgid "Screen Reader"
msgstr "Imeγri n wegdil"

#: ../src/prompt-box.vala:215
msgid "Session Options"
msgstr "Tinefrunin n tγimit"

#: ../src/session-list.vala:34
msgid "Select desktop environment"
msgstr "Fren tawennaḍt n tnarit"

#: ../src/shutdown-dialog.vala:101
msgid "Goodbye. Would you like to…"
msgstr "Ar tufat. Tebγiḍ a..."

#: ../src/shutdown-dialog.vala:105 ../src/shutdown-dialog.vala:207
msgid "Shut Down"
msgstr "Sexsi"

#: ../src/shutdown-dialog.vala:112
msgid "Are you sure you want to shut down the computer?"
msgstr "Tebγiḍ ad tessixsiḍ aselkim inek?"

#: ../src/shutdown-dialog.vala:137
msgid ""
"Other users are currently logged in to this computer, shutting down now will "
"also close these other sessions."
msgstr ""
"Iseqdacen-nniḍen qqnen akka tura s aselkim, ma tessexsiḍ-t tura ad medlent "
"tɣimiyin-nniḍen."

#: ../src/shutdown-dialog.vala:155
msgid "Suspend"
msgstr "Ḥbes di leεḍil"

#: ../src/shutdown-dialog.vala:172
msgid "Hibernate"
msgstr "Sgen"

#: ../src/shutdown-dialog.vala:190
msgid "Restart"
msgstr "Ales tanekra"

#. Translators: %s is a session name like KDE or Ubuntu
#: ../src/toggle-box.vala:98
#, c-format
msgid "%s (Default)"
msgstr "%s (Lexṣas)"

#. Help string for command line --version flag
#: ../src/unity-greeter.vala:572
msgid "Show release version"
msgstr "Sken lqem"

#. Help string for command line --test-mode flag
#: ../src/unity-greeter.vala:575
msgid "Run in test mode"
msgstr "Selkem deg uskar n usekyed"

#. Arguments and description for --help text
#: ../src/unity-greeter.vala:581
msgid "- Unity Greeter"
msgstr ""

#. Text printed out when an unknown command-line argument provided
#: ../src/unity-greeter.vala:592
#, c-format
msgid "Run '%s --help' to see a full list of available command line options."
msgstr ""
"Sekker '%s --help' iwakken ad twaliḍ tabdert tummidt n tnefrunin n "
"yinezḍayen."

#: ../src/user-list.vala:45
msgid "Guest Session"
msgstr "Tiγimit n inebgi"

#: ../src/user-list.vala:438
msgid "Please enter a complete e-mail address"
msgstr "Ttxil-k sekcem tansa imayl ummid"

#: ../src/user-list.vala:518
msgid "Incorrect e-mail address or password"
msgstr "Tansa imayl neγ awal n uɛeddi d amrmeγtu"

#: ../src/user-list.vala:549
msgid ""
"If you have an account on an RDP or Citrix server, Remote Login lets you run "
"applications from that server."
msgstr ""
"Ma tesɛiḍ amiḍan deg uqeddac RDP neɣ Citrix, tuqqna tanmeggagt ad k-teǧǧ ad "
"teslekmeḍ isnasen deg uqedac-a."

#. For 12.10 we still don't support Citrix
#: ../src/user-list.vala:551
msgid ""
"If you have an account on an RDP server, Remote Login lets you run "
"applications from that server."
msgstr ""
"Ma tesɛiḍ amiḍan deg uqeddac RDP, tuqqna tanmeggagt ad k-teǧǧ ad teslekmeḍ "
"isnasen deg uqedac-a."

#: ../src/user-list.vala:554
msgid "Cancel"
msgstr "Sefsex"

#: ../src/user-list.vala:555
msgid "Set Up…"
msgstr "Sbadu..."

#: ../src/user-list.vala:557
msgid ""
"You need an Ubuntu Remote Login account to use this service. Would you like "
"to set up an account now?"
msgstr ""
"Tesriḍ amiḍan anmeggag n tuqqna n Ubuntu iwakken ad tesqedceḍ ameẓlu-a. "
"Tebɣiḍ ad tesbaduḍ amiḍan tura?"

#: ../src/user-list.vala:561
msgid "OK"
msgstr "IH"

#: ../src/user-list.vala:562
msgid ""
"You need an Ubuntu Remote Login account to use this service. Visit "
"uccs.canonical.com to set up an account."
msgstr ""
"Tesriḍ amiḍan anmeggag n tuqqna n Ubuntu iwakken ad tesqedceḍ ameẓlu-a. Rzu "
"ɣer uccs.canonical.com iwakken ad tesbaduḍ amiḍan tura."

#: ../src/user-list.vala:679
msgid "Server type not supported."
msgstr "Anaw n uqeddac ur itteddu ara."

#: ../src/user-list.vala:720
msgid "Domain:"
msgstr "Taγult"

#: ../src/user-list.vala:781
msgid "Email address:"
msgstr "Tansa imayl:"

#. 'Log In' here is the button for logging in.
#: ../src/user-list.vala:825
msgid "Log In"
msgstr "Qqen"

#: ../src/user-list.vala:826
#, c-format
msgid "Login as %s"
msgstr "Qqen amzun d %s"

#: ../src/user-list.vala:830
msgid "Retry"
msgstr "Eɛreḍ tikkelt-nniḍen"

#: ../src/user-list.vala:831
#, c-format
msgid "Retry as %s"
msgstr "Ɛreḍ tikelt nniḍen amzun %s"

#: ../src/user-list.vala:869
msgid "Login"
msgstr "Anekcum"
